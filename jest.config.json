{
  "verbose": true,
  "errorOnDeprecated": true,
  "notify": true,
  "showSeed": true,
  "notifyMode": "failure",
  "cacheDirectory": "./tests/cache",
  "modulePaths": ["tests"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "testEnvironment": "jsdom",
  "moduleFileExtensions": ["ts", "js"],
  "displayName": "FRONT"
}